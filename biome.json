{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "files": {
    "ignore": ["**/dist/**", "**/.next/**", "**/node_modules/**", "**/target/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noDefaultExport": "error",
        "useImportType": "error",
        "useNamingConvention": "off"
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always", "trailingCommas": "all" }
  },
  "overrides": [
    {
      "include": [
        "apps/dashboard/**",
        "**/*.config.ts",
        "**/*.config.js",
        "**/*.config.mjs",
        "**/*.config.cjs",
        "**/next.config.*",
        "**/middleware.ts"
      ],
      "linter": { "rules": { "style": { "noDefaultExport": "off" } } }
    }
  ]
}
